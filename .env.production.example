# ── Скопируйте в .env.production и заполните значения ──
# cp .env.production.example .env.production

# Пароль БД. ВАЖНО: тот же пароль должен стоять в DATABASE_URL ниже.
POSTGRES_PASSWORD=ЗАМЕНИТЕ_НА_СЛОЖНЫЙ_ПАРОЛЬ

# Хост БД = имя сервиса из docker-compose (db), а не localhost.
DATABASE_URL=postgresql://postgres:ЗАМЕНИТЕ_НА_СЛОЖНЫЙ_ПАРОЛЬ@db:5432/kulstore_shop

# Секрет сессий Auth.js. Сгенерируйте: openssl rand -base64 32
AUTH_SECRET=ЗАМЕНИТЕ_openssl_rand_base64_32

# Боевой домен магазина (с https). За Nginx обязательно AUTH_TRUST_HOST=true.
AUTH_URL=https://ваш-домен.ru
AUTH_TRUST_HOST=true
NEXT_PUBLIC_BASE_URL=https://ваш-домен.ru

# Оплата: mock — магазин работает сразу, без договора с банком.
# Для реальной ЮKassa: PAYMENT_PROVIDER=yookassa + ключи ниже + webhook в кабинете.
PAYMENT_PROVIDER=mock
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=

# Учётка администратора, создаётся при первом запуске (сид). Смените пароль!
SEED_ADMIN_EMAIL=admin@kulstore.local
SEED_ADMIN_PASSWORD=Admin12345
