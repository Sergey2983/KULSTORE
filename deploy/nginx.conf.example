# KULSTORE — обратный прокси на контейнер web (127.0.0.1:3000).
# Положите в /etc/nginx/sites-available/kulstore и включите симлинком в sites-enabled,
# затем выпустите HTTPS:  sudo certbot --nginx -d ваш-домен.ru -d www.ваш-домен.ru
# certbot сам допишет блок listen 443 и редирект с http.

server {
    listen 80;
    server_name ваш-домен.ru www.ваш-домен.ru;

    # Загрузка фото товаров/слайдов — до 10 МБ (см. serverActions.bodySizeLimit).
    client_max_body_size 12m;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
